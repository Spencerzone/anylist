rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared grocery list — any signed-in user can read/write
    // Later: lock to a specific household/invite list
    match /lists/{listId}/items/{itemId} {
      allow read, write: if request.auth != null;
    }

    match /lists/{listId} {
      allow read, write: if request.auth != null;
    }
    // Shared recipes — any signed-in user can read/write
    match /recipes/{recipeId} {
      allow read, write: if request.auth != null;
    }

    // Shared meal plan — any signed-in user can read/write
    match /mealplan/{mealId} {
      allow read, write: if request.auth != null;
    }

    // Cleared item history — any signed-in user can read/write
    match /lists/{listId}/history/{histId} {
      allow read, write: if request.auth != null;
    }

    // List definitions (multi-list support) — any signed-in user can read/write
    match /listDefs/{listId} {
      allow read, write: if request.auth != null;
    }

  }
}
